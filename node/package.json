{
  "name": "2maps-loader",
  "version": "1.0.0",
  "description": "CLI tool for downloading raster map tiles to MBTiles format",
  "main": "index.js",
  "bin": {
    "2maps-loader": "./index.js"
  },
  "scripts": {
    "start": "node index.js",
    "download": "node index.js download --corner1 -90,-180 --corner2 90,180 --max-zoom 6 --url-template http://localhost:801/natural_earth/{z}/{x}/{y}.png --output d:\\natural_earth.mbtiles"
  },
  "keywords": ["maps", "tiles", "mbtiles", "cli", "download"],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "commander": "^11.1.0",
    "sqlite3": "^5.1.6",
    "axios": "^1.5.0",
    "jimp": "^0.22.10",
    "@turf/turf": "^7.3.4"
  },
  "engines": {
    "node": ">=14.0.0"
  }
}
